# ============================================================
#  SVETOZAR SCHOOL — пример переменных окружения
#  Скопируй в .env.local и заполни значения. .env.local в git НЕ коммитим.
#  Серверные секреты НЕ должны иметь префикс NEXT_PUBLIC_ (иначе попадут в браузер).
# ============================================================

# --- База данных (PostgreSQL: Neon/Supabase) ---
DATABASE_URL=

# --- Аутентификация (Auth.js / NextAuth) ---
# Сгенерировать: npx auth secret  (или openssl rand -base64 32)
AUTH_SECRET=
# Базовый URL приложения (для ссылок в письмах, OAuth-колбэков)
NEXTAUTH_URL=http://localhost:3000

# --- Anthropic (Claude API) — проверка ДЗ ИИ-наставником ---
ANTHROPIC_API_KEY=
# Модель для проверки ДЗ. Для коротких проверок подходит Haiku (дешевле/быстрее).
# Актуальные строки моделей сверяй на https://docs.claude.com
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Bunny.net Stream — видео и файлы-вложения ---
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
# Ключ для подписи ссылок (token authentication) — защита видео/файлов
BUNNY_TOKEN_AUTH_KEY=
# (опц.) Storage zone для обложек/вложений, если используется Bunny Storage
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=

# --- Email (Resend или SMTP) — подтверждение почты, сброс пароля ---
RESEND_API_KEY=
# Адрес отправителя
EMAIL_FROM=noreply@svetozar.school

# --- Telegram-бот — оповещения и результаты проверки ДЗ ---
TELEGRAM_BOT_TOKEN=
# Секрет для проверки вебхука Telegram (защита эндпоинта от подделки)
TELEGRAM_WEBHOOK_SECRET=

# --- Публичные переменные (попадают в браузер — здесь НЕТ секретов) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- (опц.) Мониторинг ошибок ---
SENTRY_DSN=
